# App / Runtime
NODE_ENV=production
LOG_LEVEL=info
PORT=3000

# Redis Connection
# Priorities: REDIS_URL > REDIS_SOCKET_PATH > REDIS_HOST/PORT
REDIS_URL=redis://:your_password@127.0.0.1:6379/0
REDIS_SOCKET_PATH=/var/run/redis/redis.sock
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=your_password

# HTTP / Security
ALLOWED_ORIGINS=*
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# Baileys Reconnect / Backoff
WS_RECONNECT_MIN_MS=2000
WS_RECONNECT_MAX_MS=30000

# Auto-Restore Sessions
RESTORE_SCAN_COUNT=200
RESTORE_LOCK_RETRIES=2
RESTORE_LOCK_RETRY_DELAY_MS=2000
AUTO_RESTORE_STARTUP_DELAY_MS=1500

# Distributed Lock
LOCK_TTL_MS=10000
LOCK_RENEW_EVERY_MS=5000

# Authentication Token Length
AUTH_TOKEN_LEN=12