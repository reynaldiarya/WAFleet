{
  "name": "wafleet",
  "version": "1.0.0",
  "description": "A high-performance, enterprise-ready WhatsApp REST API gateway built for seamless automation and integration.",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc && shx cp .env.example dist/.env && shx cp package.json dist/",
    "start": "node dist/server.js",
    "format": "prettier . --write"
  },
  "dependencies": {
    "baileys": "^7.0.0-rc13",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "multer": "^2.2.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prettier": "^3.8.3",
    "qrcode": "^1.5.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.2",
    "@types/qrcode": "^1.5.6",
    "shx": "^0.4.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
